{
    "expo": {
        "name": "Astrova",
        "slug": "astrova",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/images/icon.png",
        "userInterfaceStyle": "dark",
        "scheme": "astrova",
        "newArchEnabled": true,
        "splash": {
            "image": "./assets/images/icon.png",
            "resizeMode": "contain",
            "backgroundColor": "#000000"
        },
        "ios": {
            "supportsTablet": false,
            "bundleIdentifier": "com.yourname.astrova"
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/images/icon.png",
                "backgroundColor": "#000000"
            },
            "package": "com.yourname.astrova",
            "edgeToEdgeEnabled": true
        },
        "plugins": [
            "expo-router",
            [
                "expo-splash-screen",
                {
                    "image": "./assets/images/icon.png",
                    "imageWidth": 200,
                    "resizeMode": "contain",
                    "backgroundColor": "#000000"
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true
        }
    }
}
